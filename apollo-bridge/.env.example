# Copy to .env.local or export these in your shell. Do not commit real secrets.
TS_HOST=127.0.0.1
TS_QUERY_PORT=10022
TS_QUERY_USER=serveradmin
TS_VIRTUAL_SERVER_ID=1
TS_CHANNEL_ID=4
TS_BOT_CLIENT_ID=2

# Prefer TS_QUERY_PASSWORD_COMMAND on the EC2 host; it avoids duplicating the query password.
TS_QUERY_PASSWORD_COMMAND=sudo cat /root/teamspeak-query-admin-password

# On EC2, openai mode is the lean always-on path. Put the real key only in /opt/apollo-bridge/.env.local.
APOLLO_BRIDGE_MODE=openai
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# For local/dev mode with OpenClaw installed, set APOLLO_BRIDGE_MODE=openclaw.
OPENCLAW_BIN=openclaw
OPENCLAW_SESSION_ID=teamspeak-apollo
OPENCLAW_AGENT_ARGS=--local --json
APOLLO_BRIDGE_PREFIX=@Apollo
APOLLO_BRIDGE_COMMAND_PREFIX=!apollo
APOLLO_BRIDGE_NICKNAME=Apollo
APOLLO_BRIDGE_OUTBOX_DIR=/opt/apollo-bridge/outbox
