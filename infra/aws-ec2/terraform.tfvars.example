aws_region    = "us-east-1"
name_prefix   = "teamspeak6"
instance_type = "t3.small"

# Optional but recommended. Use your current public IP as /32.
# admin_cidrs  = ["203.0.113.10/32"]
# ssh_key_name = "my-existing-ec2-keypair"

data_volume_size_gb = 50

enable_ebs_snapshots     = true
snapshot_retention_count = 7
snapshot_time_utc        = "08:00"

# Optional DNS. hosted_zone_id is the Route 53 zone ID for example.com.
# hosted_zone_id = "Z0123456789ABCDEFG"
# dns_name       = "ts.example.com"

# Optional query/admin interfaces. Keep restricted with admin_cidrs.
# SSH Query is useful for automation/bots; HTTP Query is disabled by default.
enable_query_http = false
enable_query_ssh  = false
# query_ssh_port  = 10022
# query_http_port = 10080

# Optional ApolloBridge service on the same EC2 instance.
# Requires enable_query_ssh = true. Put real AI credentials only in
# /opt/apollo-bridge/.env.local on the host after deploy.
enable_apollo_bridge     = false
apollo_bridge_channel_id = 4
apollo_bridge_prefix     = "@Apollo"
# apollo_bridge_openai_model = "gpt-4.1-mini"

# Optional experimental real TS6 GUI client bot host.
# Creates a second EC2 instance with Xvfb/Openbox/x11vnc and the TS6 Linux client.
# Credentials stay only in /opt/apollo-gui-bot/.env.local on that host.
enable_ts6_gui_bot          = false
ts6_gui_bot_instance_type   = "t3.small"
enable_ts6_gui_bot_vnc      = true
# ts6_gui_bot_vnc_port      = 5900
