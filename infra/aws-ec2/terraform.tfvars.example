aws_region    = "us-east-1"
name_prefix   = "teamspeak6"
instance_type = "t3.small"

# Optional but recommended. Use your current public IP as /32.
# admin_cidrs  = ["203.0.113.10/32"]
# ssh_key_name = "my-existing-ec2-keypair"

data_volume_size_gb = 50

enable_ebs_snapshots     = true
snapshot_retention_count = 7
snapshot_time_utc        = "08:00"

# Optional DNS. hosted_zone_id is the Route 53 zone ID for example.com.
# hosted_zone_id = "Z0123456789ABCDEFG"
# dns_name       = "ts.example.com"

# Optional query/admin interfaces. Keep restricted with admin_cidrs.
# SSH Query is useful for automation/bots; HTTP Query is disabled by default.
enable_query_http = false
enable_query_ssh  = false
# query_ssh_port  = 10022
# query_http_port = 10080
